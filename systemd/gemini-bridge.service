[Unit]
Description=Gemini Bridge (WebAI-to-API local proxy)
After=network-online.target
Wants=network-online.target
# Cap restarts: 3 failures in 60 s, then stop (avoid tight loop on misconfig).
StartLimitIntervalSec=60
StartLimitBurst=3

[Service]
Type=simple
WorkingDirectory=%h/Documents/dev/gemini-bridge
ExecStart=%h/Documents/dev/gemini-bridge/start.sh
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
