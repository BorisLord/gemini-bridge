# Gemini Bridge — environment variables.
# Copy to `.env` (gitignored). Auto-sourced by start.sh and Docker Compose.
#
# Precedence: env > config.conf > extension/popup runtime.
# Values here override config.conf at boot. Popup OpenRouter/Gem changes live in memory until restart.

# --- Server ---

GEMINI_BRIDGE_PORT=6969

# Verbose debug logs → console + /tmp/gemini-bridge-debug.log
# GEMINI_BRIDGE_DEBUG=1

# Hard cutoff on a single Gemini call (seconds). Default 30.
# GEMINI_BRIDGE_REQUEST_TIMEOUT_SECONDS=30

# Per-tool-result cap (default: tier-adaptive 8k/32k/128k).
# GEMINI_BRIDGE_MAX_TOOL_RESULT_CHARS=8000

# --- Gemini auth (headless / no-extension) ---
# DevTools → Application → Cookies → gemini.google.com.
# If unset: [Cookies] in config.conf, then browser_cookie3 (local Chrome/Firefox profile).
# GEMINI_COOKIE_1PSID=g.a000…
# GEMINI_COOKIE_1PSIDTS=sidts-…

# Multi-account: which `/u/N` Google account. Default 0.
# GEMINI_BRIDGE_ACCOUNT_INDEX=0

# Pre-select a Gem. ID = last path segment of the Gem URL,
# e.g. https://gemini.google.com/u/0/gem/eb0eb9162487 → eb0eb9162487.
# GEMINI_BRIDGE_GEM_ID=

# --- OpenRouter fallback (free models on Gemini quota / auth errors) ---

# Default: true. Set false to bubble Gemini errors raw to the client.
# GEMINI_BRIDGE_FALLBACK_ENABLED=true

# https://openrouter.ai/keys — free tier doesn't need a credit card.
# OPENROUTER_API_KEY=sk-or-v1-…

# Free models: qwen/qwen3-coder:free, z-ai/glm-4.5-air:free,
# openai/gpt-oss-120b:free, meta-llama/llama-3.3-70b-instruct:free,
# nvidia/nemotron-3-super-120b-a12b:free.
# GEMINI_BRIDGE_FALLBACK_MODEL=qwen/qwen3-coder:free

# After successful fallback, skip Gemini for N hours. 0 = disable sticky.
# GEMINI_BRIDGE_FALLBACK_STICKY_HOURS=1

# Hard cutoff on a single OpenRouter call (seconds). Default 60.
# GEMINI_BRIDGE_OPENROUTER_TIMEOUT_SECONDS=60
