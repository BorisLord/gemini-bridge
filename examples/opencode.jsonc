// Example OpenCode config wiring Gemini Bridge as a custom provider.
// Gemini suffixes: none = free tier, `-plus` = Pro, `-advanced` = Ultra. The
// bridge accepts all regardless of your subscription — Google routes by tier
// at request time, so calling `-advanced` from a non-Ultra account may silently
// downgrade. Trim entries you don't actually have access to.
// Non-Gemini IDs (command-r-plus, qwen-3-235b, …) are routed to g4f directly
// (no Gemini call). Requires `WITH_G4F=1` setup. Full server list:
// `curl localhost:6969/v1/models`. `limit.context` / `limit.output` are
// declarative — OpenCode uses them for budgeting; the server doesn't enforce.
{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "gemini-web": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Gemini Web",
      "options": { "baseURL": "http://localhost:6969/v1", "apiKey": "dummy" },
      "models": {
        // Gemini — Free tier
        "gemini-3-pro":                     { "name": "Gemini 3 Pro",                  "limit": { "context": 1000000, "output": 65536 } },
        "gemini-3-flash":                   { "name": "Gemini 3 Flash",                "limit": { "context": 1000000, "output": 65536 } },
        "gemini-3-flash-thinking":          { "name": "Gemini 3 Thinking",             "limit": { "context": 1000000, "output": 65536 } },
        // Gemini — Pro tier
        "gemini-3-pro-plus":                { "name": "Gemini 3 Pro Plus",             "limit": { "context": 1000000, "output": 65536 } },
        "gemini-3-flash-plus":              { "name": "Gemini 3 Flash Plus",           "limit": { "context": 1000000, "output": 65536 } },
        "gemini-3-flash-thinking-plus":     { "name": "Gemini 3 Thinking Plus",        "limit": { "context": 1000000, "output": 65536 } },
        // Gemini — Ultra tier
        "gemini-3-pro-advanced":            { "name": "Gemini 3 Pro Ultra",            "limit": { "context": 1000000, "output": 65536 } },
        "gemini-3-flash-advanced":          { "name": "Gemini 3 Flash Ultra",          "limit": { "context": 1000000, "output": 65536 } },
        "gemini-3-flash-thinking-advanced": { "name": "Gemini 3 Thinking Ultra",       "limit": { "context": 1000000, "output": 65536 } },
        // Free no-auth via g4f (passthrough — bypasses Gemini entirely)
        "command-r-plus":                   { "name": "Cohere Command R+ (free, g4f)", "limit": { "context":  128000, "output": 4096 } },
        "command-a":                        { "name": "Cohere Command A (free, g4f)",  "limit": { "context":  256000, "output": 8192 } },
        "qwen-3-235b":                      { "name": "Qwen 3 235B (free, g4f)",       "limit": { "context":  128000, "output": 8192 } },
        "qwen-3-30b":                       { "name": "Qwen 3 30B (free, g4f)",        "limit": { "context":  128000, "output": 8192 } }
      }
    }
  }
}
