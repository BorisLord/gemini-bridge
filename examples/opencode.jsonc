// Suffix → Google subscription needed: none = Free, `-plus` = AI Pro, `-advanced` = AI Ultra.
// Calling a tier you don't pay for silently downgrades.
{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "gemini-web": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Gemini Web",
      "options": { "baseURL": "http://localhost:6969/v1", "apiKey": "dummy" },
      "models": {
        "gemini-3-pro-advanced":             { "name": "Ultra · Pro",            "limit": { "context": 1000000, "output": 65536 } },
        "gemini-3-flash-advanced":           { "name": "Ultra · Flash",          "limit": { "context": 1000000, "output": 65536 } },
        "gemini-3-flash-thinking-advanced":  { "name": "Ultra · Flash Thinking", "limit": { "context": 1000000, "output": 65536 } },
        "gemini-3-pro-plus":                 { "name": "Pro · Pro",              "limit": { "context": 1000000, "output": 65536 } },
        "gemini-3-flash-plus":               { "name": "Pro · Flash",            "limit": { "context": 1000000, "output": 65536 } },
        "gemini-3-flash-thinking-plus":      { "name": "Pro · Flash Thinking",   "limit": { "context": 1000000, "output": 65536 } },
        "gemini-3-pro":                      { "name": "Free · Pro",             "limit": { "context": 1000000, "output": 65536 } },
        "gemini-3-flash":                    { "name": "Free · Flash",           "limit": { "context": 1000000, "output": 65536 } },
        "gemini-3-flash-thinking":           { "name": "Free · Flash Thinking",  "limit": { "context": 1000000, "output": 65536 } }
      }
    }
  }
}
