// Zed — drop this `language_models.openai_compatible` block into ~/.config/zed/settings.json.
// Suffix mapping: `-advanced` = AI Ultra, `-plus` = AI Pro, none = Free.
// Calling a tier you don't pay for silently downgrades.
//
// Required env: export GEMINI_BRIDGE_API_KEY=dummy   (the bridge ignores the value, but Zed must
// see a non-empty env var matching the provider name in upper-snake-case + `_API_KEY`).
//
// Routing is MANDATORY: every model name MUST carry an `@<account_id>` suffix
// — bare names get rejected with 400. List your registered accounts with
// `curl http://localhost:6969/accounts/`. Replace `firefox:0` below with the
// id(s) you actually have. Duplicate per account for multi-account quotas.
{
  "language_models": {
    "openai_compatible": {
      "Gemini Bridge": {
        "api_url": "http://localhost:6969/v1",
        "available_models": [
          { "name": "gemini-3-pro-advanced@firefox:0",            "display_name": "Ultra · Pro",            "max_tokens": 1000000, "max_output_tokens": 65536 },
          { "name": "gemini-3-flash-advanced@firefox:0",          "display_name": "Ultra · Flash",          "max_tokens": 1000000, "max_output_tokens": 65536 },
          { "name": "gemini-3-flash-thinking-advanced@firefox:0", "display_name": "Ultra · Flash Thinking", "max_tokens": 1000000, "max_output_tokens": 65536 },
          { "name": "gemini-3-pro-plus@firefox:0",                "display_name": "Pro · Pro",              "max_tokens": 1000000, "max_output_tokens": 65536 },
          { "name": "gemini-3-flash-plus@firefox:0",              "display_name": "Pro · Flash",            "max_tokens": 1000000, "max_output_tokens": 65536 },
          { "name": "gemini-3-flash-thinking-plus@firefox:0",     "display_name": "Pro · Flash Thinking",   "max_tokens": 1000000, "max_output_tokens": 65536 },
          { "name": "gemini-3-pro@firefox:0",                     "display_name": "Free · Pro",             "max_tokens": 1000000, "max_output_tokens": 65536 },
          { "name": "gemini-3-flash@firefox:0",                   "display_name": "Free · Flash",           "max_tokens": 1000000, "max_output_tokens": 65536 },
          { "name": "gemini-3-flash-thinking@firefox:0",          "display_name": "Free · Flash Thinking",  "max_tokens": 1000000, "max_output_tokens": 65536 }

          // ── Add a second account by duplicating any line above and changing
          //    both the `@<id>` suffix and the display name. Leading-comma style:
          //    just remove the `// ` prefix, no other edit.
          // ,{ "name": "gemini-3-pro-plus@extension:0", "display_name": "Pro · Pro · Chrome",     "max_tokens": 1000000, "max_output_tokens": 65536 }
          // ,{ "name": "gemini-3-pro-plus@firefox:1",   "display_name": "Pro · Pro · Firefox #2", "max_tokens": 1000000, "max_output_tokens": 65536 }
        ]
      }
    }
  }
}
