# Open WebUI — drop into your `.env` (or pass as Docker env vars).
# https://docs.openwebui.com/getting-started/env-configuration
#
# After restart, every Gemini Bridge model appears in the model picker.
# Add more endpoints by separating URLs and keys with `;` (parallel arrays).

ENABLE_OPENAI_API=true

# If Open WebUI runs in Docker and the bridge runs on the host, replace
# `localhost` with `host.docker.internal` (Mac / Win) or `172.17.0.1`
# (Linux native Docker), or run both in the same docker network.
OPENAI_API_BASE_URLS=http://localhost:6969/v1
OPENAI_API_KEYS=dummy
