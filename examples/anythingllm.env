# AnythingLLM — drop into your `.env`. Switch models per workspace via the UI;
# the variables below set the default LLM and the boot-time model.
# https://docs.anythingllm.com

LLM_PROVIDER=generic-openai

# If AnythingLLM runs in Docker and the bridge runs on the host, replace
# `localhost` with `host.docker.internal` (Mac / Win) or `172.17.0.1`
# (Linux native Docker).
GENERIC_OPEN_AI_BASE_PATH=http://localhost:6969/v1
GENERIC_OPEN_AI_API_KEY=dummy
GENERIC_OPEN_AI_MODEL_PREF=gemini-3-pro-plus
GENERIC_OPEN_AI_MODEL_TOKEN_LIMIT=1000000
GENERIC_OPEN_AI_MAX_TOKENS=65536
